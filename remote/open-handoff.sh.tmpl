#!/bin/zsh
# agent-mac-ops `open` shim (lives at ~/bin/open ON THE REMOTE; rendered+pushed by
# setup.sh). Shadows /usr/bin/open in the dev session: http(s) URLs are sent back
# to the control Mac over the reverse tunnel so the page opens on YOUR machine.
# Anything else (files, apps) falls through to the real /usr/bin/open. If the tunnel
# is down, falls back to opening the URL locally so nothing silently breaks.
PORT="@@HANDOFF_PORT@@"
TOKEN="@@HANDOFF_TOKEN@@"

for a in "$@"; do
  case "$a" in
    http://*|https://*)
      if ! curl -s --max-time 3 "http://localhost:$PORT/open" \
             --data-urlencode "token=$TOKEN" --data-urlencode "url=$a" >/dev/null 2>&1; then
        /usr/bin/open "$a"   # tunnel/listener unavailable → open here as a fallback
      fi ;;
    *) /usr/bin/open "$a" ;;
  esac
done
