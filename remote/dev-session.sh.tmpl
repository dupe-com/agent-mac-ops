#!/bin/zsh
# agent-mac-ops dev session (lives on the remote; rendered + pushed by setup.sh).
#
# Called as:  dev-session.sh [mode]
#   (none)|iterm     iTerm2 control mode — `tmux -CC attach` renders the remote tmux
#                    session as NATIVE iTerm windows/panes that reattach. -CC is an
#                    iTerm2-only protocol; this is the classic path.
#   ghostty-native   Ghostty has no -CC, so its "native" is Ghostty's OWN splits —
#                    each surface gets a fresh remote login shell (no tmux layout).
#                    The auto-ssh-per-split is driven from control/bin/ghostty-connect.sh.
#   ghostty-tmux     Ghostty + persistence: plain `tmux attach` (tmux-drawn panes,
#                    tmux keybinds) so the session survives disconnect.
#   mosh             Same persistent tmux attach, reached over mosh (predictive local
#                    echo) for snappy typing on a laggy link. Terminal-agnostic.
#
# Connect ONCE per iTerm session; use iTerm shortcuts after (re-running -CC spawns a
# 2nd client). For Ghostty, every native split runs this fresh — that's the point.
export PATH=/opt/homebrew/bin:/usr/local/bin:$PATH

# If the client's TERM has no terminfo entry here, fall back to a universally
# present one. A missing entry (e.g. xterm-ghostty when Ghostty's terminfo isn't
# installed on this Mac) breaks ZLE cursor addressing and shows up as garbled or
# DOUBLED keystrokes. `setup.sh remote` tries to install xterm-ghostty for full
# fidelity; this guard keeps things sane either way.
infocmp "$TERM" >/dev/null 2>&1 || export TERM=xterm-256color

# Browser handoff: if the `open` shim was pushed (./setup.sh remote with handoff
# enabled), route http(s) URLs opened in this session back to the control Mac.
# Harmless if absent — only activates when the shim exists.
[ -x "$HOME/bin/open" ] && { export PATH="$HOME/bin:$PATH"; export BROWSER="$HOME/bin/open"; }

SESSION="@@TMUX_SESSION@@"
WORK_DIR="@@WORK_DIR@@"
WORK_DIR="${WORK_DIR/#\~/$HOME}"   # expand a leading ~ on the remote
MODE="${1:-iterm}"

# Ghostty replacement for iTerm's Automatic Profile Switching: tint THIS surface's
# background so the remote is unmistakable, then reset on exit. The escape travels
# back over the ssh pty to your local Ghostty. Unlike iTerm APS, Ghostty won't
# auto-revert, so the EXIT trap clears it (control/bin/ghostty-connect.sh adds a
# local safety-net for hard drops). We DON'T exec the shell/tmux in the Ghostty
# modes so the trap can still fire when it exits.
REMOTE_COLOR="@@GHOSTTY_REMOTE_COLOR@@"
tint()   { [ -n "$REMOTE_COLOR" ] && printf '\033]11;%s\a' "$REMOTE_COLOR"; }
untint() { [ -n "$REMOTE_COLOR" ] && printf '\033]111\a'; }

# Make native splits inherit the active pane's directory. iTerm's ⌘D (and Ghostty
# under tmux) issue a BARE `split-window`/`new-window` over the control channel, so
# tmux takes the cwd from the ISSUING CLIENT — the GUI app, whose cwd is `/` — not
# the current pane. (Prefix-key binds can use `-c #{pane_current_path}`, but ⌘D never
# triggers them.) command-alias rewrites the built-in commands themselves, so even a
# bare split inherits the pane's path. Non-recursive; stacks harmlessly with any
# `-c` already on a keybind (last `-c` wins, same value). Global/server option —
# setting it on each connect is idempotent.
tmux_inherit_cwd() {
  tmux set -g "command-alias[100]" "split-window=split-window -c \"#{pane_current_path}\"" 2>/dev/null
  tmux set -g "command-alias[101]" "new-window=new-window -c \"#{pane_current_path}\"" 2>/dev/null
}

case "$MODE" in
  ghostty-native)
    export COLORTERM=truecolor   # client is Ghostty → keep 24-bit color even on the xterm-256color fallback
    tint; trap untint EXIT INT TERM
    cd "$WORK_DIR" 2>/dev/null || cd "$HOME"
    "${SHELL:-/bin/zsh}" -l ;;

  ghostty-tmux|mosh)
    # mosh has its own terminal model and may swallow the OSC-11 tint; it's emitted
    # anyway (harmless) — the persistence + snappy echo are the point of this mode.
    export COLORTERM=truecolor
    tint; trap untint EXIT INT TERM
    tmux has-session -t "$SESSION" 2>/dev/null || tmux new-session -d -s "$SESSION" -c "$WORK_DIR"
    tmux_inherit_cwd
    tmux attach -t "$SESSION" ;;

  *)  # iterm / default — control mode, native iTerm panes
    tmux has-session -t "$SESSION" 2>/dev/null || tmux new-session -d -s "$SESSION" -c "$WORK_DIR"
    tmux_inherit_cwd
    exec tmux -CC attach -t "$SESSION" ;;
esac
