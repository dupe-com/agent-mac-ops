# agent-mac-ops configuration.
# Copy to config.env (gitignored) or let `./setup.sh` write it for you.
# Every script sources these values; the two *.tmpl files are rendered from them.

# --- connection ---
# SSH target for your always-on Mac. Anything your `ssh` can already reach.
# Tailscale is recommended (no public exposure) but not required — set up an
# ~/.ssh/config Host alias and put its name here.
REMOTE_HOST="my-mac"

# The remote's short hostname (run `hostname -s` ON the remote). Drives the
# iTerm2 Automatic Profile Switching rule:  <you>@<REMOTE_HOSTNAME>*
REMOTE_HOSTNAME="My-Mac"

# --- session ---
# Directory the tmux dev session opens in, ON THE REMOTE. Use "~" for the
# remote home, "~/path" (expanded on the remote), or an absolute path.
WORK_DIR="~"
# tmux session name.
TMUX_SESSION="dev"
# The shell command you'll type locally to connect.
ALIAS_NAME="box"
# iTerm2 profile name you create for the remote (see SETUP.md). Informational
# here — APS binds it by hostname; this just lets docs/messages name it.
PROFILE_NAME="Remote"
# Ghostty only: background tint for remote surfaces — Ghostty's stand-in for iTerm
# Automatic Profile Switching (Ghostty has no APS). The remote shell emits an OSC
# 11 to set this on connect and resets it on exit. Any hex Ghostty accepts; blank =
# no tint. Pick something clearly different from your local background.
GHOSTTY_REMOTE_COLOR="#2a1f3d"
# Absolute path to mosh-server ON THE REMOTE, powering the `<alias>-mosh` command
# (predictive-echo typing for laggy links). `./setup.sh remote` discovers this and
# fills it in (macOS Homebrew puts mosh-server outside ssh's non-interactive PATH,
# so the launcher pins it). Leave blank — it auto-populates.
MOSH_SERVER=""

# --- notifications (optional) ---
# Webhook for the daily health digest. Slack/Mattermost use {"text": ...};
# Discord uses {"content": ...} — set NOTIFY_KEY to match. Blank = log-only.
# Keep this file gitignored; use a webhook URL, never a bare token.
NOTIFY_WEBHOOK=""
NOTIFY_KEY="text"

# --- port forwarding & remote auth ---
# Ports auto-forwarded to the remote every time you connect with the alias
# (space-separated). Your Mac's localhost:<port> → the remote's localhost:<port>,
# so remote dev servers AND OAuth localhost callbacks reach you. Blank = none.
FORWARD_PORTS="3000 8080"
# Browser handoff: when a tool ON THE REMOTE opens an http(s) URL (e.g. an OAuth
# consent page), open it on THIS Mac instead — no Screen Sharing. Requires
# `./setup.sh remote` (pushes the `open` shim) + install-open-listener.sh.
HANDOFF_ENABLED="true"
HANDOFF_PORT="17999"
HANDOFF_TOKEN=""   # generated by setup.sh; shared secret between shim and listener

# --- optional extras ---
# An extra remote log file to surface in logs.sh (e.g. your app's dev log).
EXTRA_LOG=""
# Daily-check time (24h, control-machine local). Used by install-launchd.sh.
CHECK_HOUR="9"
CHECK_MIN="0"
