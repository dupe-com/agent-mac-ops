#!/bin/bash
# Team Mac user management
#
# Usage:
#   ./users                  show users + help
#   ./users list             list provisioned users
#   ./users add [username]   full onboarding flow (invite → provision)
#   ./users invite [username] generate invite script only
#   ./users provision [username] provision after receiving their SSH key
set -euo pipefail

ROOT="$(cd "$(dirname "$0")" && pwd)"
CONFIG="$ROOT/config.env"
REGISTRY="$ROOT/docs/host-registry.md"
CONTROL="$ROOT/control/bin"

# ── colors ───────────────────────────────────────────────────────────────────
if [[ -t 1 ]]; then
  BOLD=$(tput bold); GREEN=$(tput setaf 2); CYAN=$(tput setaf 6)
  YELLOW=$(tput setaf 3); DIM=$(tput dim); RESET=$(tput sgr0)
else
  BOLD=""; GREEN=""; CYAN=""; YELLOW=""; DIM=""; RESET=""
fi

ok()   { echo "  ${GREEN}✓${RESET}  $*"; }
note() { echo "  ${YELLOW}→${RESET}  $*"; }
err()  { echo "  ✗  $*" >&2; }
hr()   { echo "${DIM}$(printf '%.0s─' $(seq 1 62))${RESET}"; }
hdr()  { hr; echo "  ${BOLD}$*${RESET}"; hr; }

# ── sanity checks ─────────────────────────────────────────────────────────────
if [[ ! -f "$CONFIG" ]]; then
  err "config.env not found — run ./setup.sh first."
  exit 1
fi
. "$CONFIG"

# ── helpers ───────────────────────────────────────────────────────────────────

# Print the user table from host-registry.md (or a "none yet" message)
list_users() {
  if [[ ! -f "$REGISTRY" ]]; then
    echo "  ${DIM}(none yet)${RESET}"
    return
  fi
  local found=0
  while IFS='|' read -r _ user index ip host _; do
    user=$(echo "$user" | xargs); index=$(echo "$index" | xargs)
    ip=$(echo "$ip" | xargs); host=$(echo "$host" | xargs)
    [[ -z "$user" || "$user" == "User" || "$user" == "---"* ]] && continue
    printf "  ${BOLD}%-12s${RESET}  slot %-2s  ${CYAN}%-16s${RESET}  %s\n" \
      "$user" "$index" "$ip" "$host"
    found=1
  done < "$REGISTRY"
  [[ $found -eq 0 ]] && echo "  ${DIM}(none yet)${RESET}"
}

# Return the lowest free index (1-9) not already in the registry
next_index() {
  local taken=()
  if [[ -f "$REGISTRY" ]]; then
    while IFS='|' read -r _ _ index _; do
      local idx; idx=$(echo "$index" | xargs)
      [[ "$idx" =~ ^[0-9]+$ ]] && taken+=("$idx")
    done < "$REGISTRY"
  fi
  for i in $(seq 1 9); do
    local used=0
    for t in "${taken[@]:-}"; do [[ "$t" == "$i" ]] && used=1 && break; done
    [[ $used -eq 0 ]] && echo "$i" && return
  done
  err "All 9 slots are taken."
  exit 1
}

# Look up a user's index from the registry; echoes empty string if not found
lookup_index() {
  local target="$1"
  [[ ! -f "$REGISTRY" ]] && return
  while IFS='|' read -r _ user index _; do
    local u; u=$(echo "$user" | xargs)
    if [[ "$u" == "$target" ]]; then
      echo "$index" | xargs
      return
    fi
  done < "$REGISTRY"
}

# Prompt for a username if not supplied as arg
require_username() {
  local name="${1:-}"
  if [[ -z "$name" ]]; then
    echo ""
    read -r -p "  Username: " name
  fi
  [[ -z "$name" ]] && err "Username required." && exit 1
  echo "$name"
}

# ── commands ──────────────────────────────────────────────────────────────────

cmd_list() {
  echo ""
  hdr "Users — $REMOTE_HOST"
  echo ""
  list_users
  echo ""
}

cmd_invite() {
  local username; username=$(require_username "${1:-}")
  local index; index=$(next_index)

  echo ""
  hdr "Generating invite for ${username}"
  echo ""
  note "Assigning slot ${index}  →  ${username}.studio (127.0.0.${index})"
  echo ""

  "$CONTROL/generate-invite.sh" "$username" "$index"

  echo ""
  note "Next: send ${username} the file above, then run:"
  echo ""
  echo "    ${BOLD}./users provision ${username}${RESET}"
  echo ""
}

cmd_provision() {
  local username; username=$(require_username "${1:-}")
  local index; index=$(lookup_index "$username")

  if [[ -z "$index" ]]; then
    echo ""
    note "$username isn't in the registry yet."
    echo ""
    read -r -p "  Which slot should they use? (1-9): " index
    [[ ! "$index" =~ ^[1-9]$ ]] && err "Slot must be 1-9." && exit 1
  fi

  echo ""
  hdr "Provisioning ${username}  (slot ${index})"
  echo ""

  "$CONTROL/provision-user.sh" "$username" "$index"
}

cmd_add() {
  local username; username=$(require_username "${1:-}")
  local index; index=$(next_index)

  echo ""
  hdr "Adding ${username}"
  echo ""
  note "Assigning slot ${index}  →  ${username}.studio (127.0.0.${index})"
  echo ""

  # Always generate the invite script first so they can onboard themselves
  "$CONTROL/generate-invite.sh" "$username" "$index"

  echo ""
  hr
  echo ""
  read -r -p "  Do you already have ${username}'s SSH key? [y/N] " has_key
  echo ""

  if [[ "$has_key" =~ ^[Yy]$ ]]; then
    "$CONTROL/provision-user.sh" "$username" "$index"
  else
    note "Send them ${BOLD}onboard/${username}-setup.sh${RESET}, then run:"
    echo ""
    echo "    ${BOLD}./users provision ${username}${RESET}"
    echo ""
  fi
}

cmd_help() {
  echo ""
  hdr "Team Mac — User Management"
  echo ""
  list_users
  echo ""
  echo "  ${BOLD}Commands${RESET}"
  echo ""
  echo "    ${CYAN}./users add [name]${RESET}        onboard a new user end-to-end"
  echo "    ${CYAN}./users invite [name]${RESET}     generate their setup script only"
  echo "    ${CYAN}./users provision [name]${RESET}  provision after receiving their SSH key"
  echo "    ${CYAN}./users list${RESET}              show current users"
  echo ""
  hr
  echo ""
}

# ── dispatch ──────────────────────────────────────────────────────────────────
case "${1:-help}" in
  add|new)      cmd_add      "${2:-}" ;;
  invite)       cmd_invite   "${2:-}" ;;
  provision)    cmd_provision "${2:-}" ;;
  list|ls)      cmd_list ;;
  help|--help)  cmd_help ;;
  *)
    # Unknown arg or bare username — treat as ./users add <name>
    if [[ -n "${1:-}" ]]; then
      cmd_add "$1"
    else
      cmd_help
    fi
    ;;
esac
