# agent-mac-ops — `@@ALIAS_NAME@@` opens your always-on Mac as a NATIVE remote
# session. It adapts to your terminal:
#   • iTerm2  → `tmux -CC` control mode = native iTerm panes that reattach (classic).
#   • Ghostty → a new Ghostty instance whose every native split/tab (Cmd+D / Cmd+T)
#               auto-ssh's into the remote. Ghostty has no -CC; this is the closest
#               native equivalent. `@@ALIAS_NAME@@-tmux` trades native splits for a
#               persistent tmux session that survives disconnect. See SETUP.md.
# `@@ALIAS_NAME@@-mosh` (either terminal) trades native panes for mosh's predictive
# local echo — the fix for laggy typing on a high-latency link.
#
# Source this from ~/.zshrc, BEFORE your iTerm2 shell-integration line: iTerm2's
# shell integration self-disables inside tmux (when $TERM is tmux/screen), so
# RemoteHost is never reported from a `tmux -CC` session and Automatic Profile
# Switching can't recolor. This flag forces it back on — load-bearing for the iTerm
# path, harmless for Ghostty.
export ITERM_ENABLE_SHELL_INTEGRATION_WITH_TMUX=1

# Shared SSH master (same ControlPath as box-fwd). The first connection opens it
# WITH the forwards below; later Ghostty splits ride it → instant, no re-auth, and
# only the master holds the forwards so splits never collide on the -R tunnel.
_amo_cp="$HOME/.ssh/cm-%r@%h:%p"

# @@SSH_FORWARDS@@ = reverse tunnel for browser handoff (-R) + any FORWARD_PORTS
# (-L), so remote dev servers and OAuth localhost callbacks reach your Mac.
#
# The forwards ride the DETACHED master (_amo_master), never this -CC connection.
# Why it matters: a -L forward pointed at a dev server you just stopped will spew
# "channel N: open failed: connect failed" every time the page polls it. On the
# tmux -CC connection those bytes corrupt the control protocol and iTerm force-
# quits tmux mode (closing your window). On the detached master, stderr is sent to
# /dev/null, so the noise is harmless. The -CC session opens as its own clean,
# independent connection (ControlPath=none) carrying only the tmux protocol; -q
# silences any residual client chatter.
_amo_iterm() {
  _amo_master
  ssh -tq -o ControlPath=none @@REMOTE_HOST@@ '~/dev-session.sh'
}

_amo_master() {   # ensure one multiplexed master carrying the forwards
  ssh -o ControlPath="$_amo_cp" -O check @@REMOTE_HOST@@ 2>/dev/null && return 0
  ssh -o ControlMaster=yes -o ControlPath="$_amo_cp" -o ControlPersist=4h \
      -fNT @@SSH_FORWARDS@@ @@REMOTE_HOST@@ 2>/dev/null || true
}

_amo_ghostty() {  # $1 = native | tmux
  _amo_master
  open -na Ghostty --args \
    --command="@@ROOT@@/control/bin/ghostty-connect.sh ${1:-native}" \
    --shell-integration-features=ssh-env,ssh-terminfo \
    --title="@@REMOTE_HOST@@ · ${1:-native}" \
  || { echo "@@ALIAS_NAME@@: couldn't launch Ghostty — is it installed?" >&2; return 1; }
}

# Clear any prior alias of these names (older versions of this snippet defined
# `@@ALIAS_NAME@@` as an alias; zsh won't let a function shadow an existing alias).
unalias @@ALIAS_NAME@@ @@ALIAS_NAME@@-tmux 2>/dev/null || true

# Native remote session — Ghostty native splits, or iTerm -CC if you're in iTerm.
@@ALIAS_NAME@@() {
  case "${TERM_PROGRAM:-}" in
    ghostty) _amo_ghostty native ;;
    *)       _amo_iterm ;;
  esac
}

# Persistent remote session (survives disconnect). Ghostty: tmux-drawn panes. Under
# iTerm the default `@@ALIAS_NAME@@` already persists via -CC, so this defers to it.
@@ALIAS_NAME@@-tmux() {
  case "${TERM_PROGRAM:-}" in
    ghostty) _amo_ghostty tmux ;;
    *) echo "iTerm's @@ALIAS_NAME@@ already persists via tmux -CC — just run: @@ALIAS_NAME@@" >&2 ;;
  esac
}

# Snappy typing over a laggy link: mosh adds PREDICTIVE LOCAL ECHO — characters
# appear instantly and reconcile with the server async, the one thing that beats the
# SSH round-trip floor. It's a single UDP session (no -CC, no native splits) and
# CAN'T carry forwards, so we still bring up the detached SSH master first (it holds
# browser handoff + FORWARD_PORTS), and mosh runs `tmux attach` inside dev-session so
# the session survives drops + gives you panes. Works in iTerm and Ghostty alike.
# Needs mosh on both ends (./setup.sh remote installs it) + UDP 60000-61000 reachable
# (Tailscale carries it). MOSH_SERVER is the remote mosh-server path baked by setup.sh
# (macOS Homebrew puts it outside ssh's non-interactive PATH, so we point at it).
@@ALIAS_NAME@@-mosh() {
  command -v mosh >/dev/null || { echo "@@ALIAS_NAME@@-mosh: mosh not installed locally — brew install mosh" >&2; return 1; }
  _amo_master
  local srv="@@MOSH_SERVER@@"
  mosh ${srv:+--server="$srv"} @@REMOTE_HOST@@ -- /bin/zsh -lc '~/dev-session.sh mosh'
}

# Ad-hoc forwarding without reconnecting (handles random OAuth callback ports):
#   @@ALIAS_NAME@@-fwd 54321            forward localhost:54321 ⇄ remote
#   @@ALIAS_NAME@@-fwd oauth '<url>'    forward the URL's callback port + open it here
#   @@ALIAS_NAME@@-fwd cancel 54321     stop forwarding it
alias @@ALIAS_NAME@@-fwd="@@ROOT@@/control/bin/box-fwd.sh"

# Push your clipboard IMAGE to the remote's clipboard (screenshots → Ctrl+V in a
# tool running on the remote, e.g. Claude Code). Terminals forward clipboard text
# only, never image bytes, so this bridges it. Copy a shot (Cmd+Ctrl+Shift+4) then:
#   @@ALIAS_NAME@@-clip
alias @@ALIAS_NAME@@-clip="@@ROOT@@/control/bin/clip-push.sh"

# Move files to/from the remote without typing the host (rsync -avzP under the hood):
#   @@ALIAS_NAME@@-push ~/Downloads/x.json        send to remote home
#   @@ALIAS_NAME@@-push ./dist ~/deploys/         send to a remote dir
#   @@ALIAS_NAME@@-pull ~/Work/app/out.csv        fetch into cwd
alias @@ALIAS_NAME@@-push="@@ROOT@@/control/bin/xfer.sh push"
alias @@ALIAS_NAME@@-pull="@@ROOT@@/control/bin/xfer.sh pull"

# Open your LOCAL Cursor/VS Code in Remote-SSH mode at a folder ON THE REMOTE — the
# `code .` equivalent, run from your laptop without first connecting a session.
# (Inside a connected session, use `code-@@ALIAS_NAME@@` instead — it knows the cwd.)
# Defaults to your configured work dir; resolves ~ on the remote via the shared master.
#   @@ALIAS_NAME@@-code                 open the work dir
#   @@ALIAS_NAME@@-code apps/web        open a path under the work dir
#   @@ALIAS_NAME@@-code '~/other'       open an absolute/~ remote path
@@ALIAS_NAME@@-code() {
  command -v cursor >/dev/null 2>&1 && local ed=cursor || local ed=code
  command -v "$ed" >/dev/null 2>&1 || { echo "@@ALIAS_NAME@@-code: no cursor/code CLI on this Mac" >&2; return 1; }
  _amo_master
  local req="${1:-@@WORK_DIR@@}"
  case "$req" in /*|"~"*) : ;; *) req="@@WORK_DIR@@/$req" ;; esac
  local abs; abs="$(ssh -o ControlPath="$_amo_cp" @@REMOTE_HOST@@ "cd \"$req\" 2>/dev/null && pwd")" \
    || { echo "@@ALIAS_NAME@@-code: no such directory on @@REMOTE_HOST@@: $req" >&2; return 1; }
  "$ed" --remote "ssh-remote+@@REMOTE_HOST@@" "$abs"
}
