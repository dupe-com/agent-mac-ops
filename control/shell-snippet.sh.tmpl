# agent-mac-ops — type `@@ALIAS_NAME@@` to open your always-on Mac as NATIVE iTerm
# windows/panes (resizable, real Cmd+D / Cmd+T splits connected to the remote).
#
# Source this from ~/.zshrc, BEFORE your iTerm2 shell-integration line. iTerm2's
# shell integration self-disables inside tmux (when $TERM is tmux/screen), so
# RemoteHost is never reported from inside a `tmux -CC` session and Automatic
# Profile Switching can't recolor the window. This flag forces it back on — it
# is the load-bearing fix that makes the whole thing work.
export ITERM_ENABLE_SHELL_INTEGRATION_WITH_TMUX=1

# Connect. @@SSH_FORWARDS@@ carries the reverse tunnel for browser handoff (-R)
# plus any FORWARD_PORTS (-L), so dev servers and OAuth localhost callbacks on the
# remote are reachable at your Mac's localhost for the life of the session.
alias @@ALIAS_NAME@@="ssh -t @@SSH_FORWARDS@@ @@REMOTE_HOST@@ '~/dev-session.sh'"

# Ad-hoc forwarding without reconnecting (handles random OAuth callback ports):
#   @@ALIAS_NAME@@-fwd 54321            forward localhost:54321 ⇄ remote
#   @@ALIAS_NAME@@-fwd oauth '<url>'    forward the URL's callback port + open it here
#   @@ALIAS_NAME@@-fwd cancel 54321     stop forwarding it
alias @@ALIAS_NAME@@-fwd="@@ROOT@@/control/bin/box-fwd.sh"
